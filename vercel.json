{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/utils?action=sitemap"
    },
    {
      "source": "/api/sitemap",
      "destination": "/api/utils?action=sitemap"
    },
    {
      "source": "/api/og-image",
      "destination": "/api/utils?action=og-image"
    },
    {
      "source": "/api/newsletter",
      "destination": "/api/utils?action=newsletter"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/checkout/",
      "destination": "/checkout.html"
    },
    {
      "source": "/products/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/blog/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api(?:/|$)|.*\\.[a-zA-Z0-9]{2,8}$).*)",
      "destination": "/index.html"
    }
  ]
}
